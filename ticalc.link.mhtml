@charset "utf-8";

html, body, * { margin: 0px; padding: 0px; box-sizing: border-box; }

body { background-color: rgb(245, 245, 245); position: relative; }

h1, h2, p, a { text-align: center; color: rgb(68, 68, 68); font-family: Roboto, Tahoma, Arial, sans-serif; }

h1 { font-size: 3em; margin: 0px 0px 0.2em; font-variant: small-caps; }

h2 { font-size: 1.8em; margin: 0px 0px 1em; }

pre { color: rgb(68, 68, 68); max-width: 500px; margin: 1em auto; }

main { min-height: 100vh; display: flex; align-items: center; justify-content: center; }

main > section { display: none; width: 100vw; padding: 2em; }

main > section.active { display: block; }

main > section#incompatible { padding-bottom: 5em; }

@media screen and (max-width: 600px) {
  main > section { padding-bottom: 8em; }
}

footer { position: absolute; bottom: 0px; left: 0px; right: 0px; padding: 1em; font-size: 0.8em; text-align: left; }

footer p, footer a { color: rgb(145, 145, 145); }

#popup { position: fixed; inset: 0px; display: flex; align-items: center; justify-content: center; background-color: rgba(0, 0, 0, 0); pointer-events: none; transition: background-color 0.2s; }

#popup.active { background-color: rgba(0, 0, 0, 0.4); pointer-events: all; }

#popup.active #content { transform: scale(1); opacity: 1; }

#popup #content { max-width: 450px; padding: 2em; border-radius: 10px; background-color: rgb(245, 245, 245); box-shadow: rgba(0, 0, 0, 0.75) 0px 0px 33px -10px; transition: transform 0.2s, opacity 0.2s; transform: scale(0.7); opacity: 0; }

#popup #content .buttons { text-align: center; margin: 1em auto 0px; }

#popup #content .buttons button { margin: 1em; padding: 1em 1.5em; color: rgb(238, 238, 238); border-radius: 5px; border: 0px; cursor: pointer; font-family: Roboto, Tahoma, Arial, sans-serif; font-size: 0.9em; }

#popup #content .buttons button.yes { background-color: rgb(54, 162, 82); }

#popup #content .buttons button.yes:focus { background-color: rgb(50, 151, 76); }

#popup #content .buttons button.yes:hover { background-color: rgb(58, 173, 88); }

#popup #content .buttons button.no { background-color: rgb(228, 82, 82); }

#popup #content .buttons button.no:focus { background-color: rgb(226, 69, 69); }

#popup #content .buttons button.no:hover { background-color: rgb(230, 95, 95); }

main section.buttons { display: flex; flex-direction: row; align-items: center; justify-content: center; margin: 2em; }

main section.buttons button { width: 20vw; max-width: 200px; min-width: 140px; height: 20vw; max-height: 200px; min-height: 140px; margin: 5vh 2vw; border-radius: 50%; background-color: rgb(205, 205, 206); border: 0px; cursor: default; color: rgb(136, 136, 136); font-family: Roboto, Tahoma, Arial, sans-serif; transition: background-color 0.2s, border 0.2s; }

main section.buttons button.active { background-color: rgb(50, 55, 212); cursor: pointer; color: rgb(238, 238, 238); }

main section.buttons button.active:focus { background-color: rgb(43, 48, 204); }

main section.buttons button.active:hover { background-color: rgb(63, 67, 215); }

main section.buttons button.complete { background-color: rgb(54, 162, 82); cursor: pointer; color: rgb(238, 238, 238); }

main section.buttons button.complete:focus { background-color: rgb(51, 154, 78); }

main section.buttons button.complete:hover { background-color: rgb(57, 170, 86); }

main section.buttons button.complete span { color: rgb(54, 162, 82); font-size: 0px; width: 38px; height: 57px; padding-top: 6px; margin: 0px auto; }

main section.buttons button.complete span::before { content: " "; left: 50px; display: block; box-sizing: content-box; width: 28px; height: 15px; border-width: 0px 0px 5px 5px; border-style: none none solid solid; border-color: currentcolor currentcolor white white; border-image: initial; transform: translate(0px, 18px) rotate(-45deg); transform-origin: left top; animation: 0.6s ease 0s 1 normal none running checkmark-animation; }

@-webkit-keyframes checkmark-animation { 
  0% { height: 0px; width: 0px; opacity: 1; }
  50% { height: 15px; width: 0px; opacity: 1; }
  100% { height: 15px; width: 28px; opacity: 1; }
}

@keyframes checkmark-animation { 
  0% { height: 0px; width: 0px; opacity: 1; }
  50% { height: 15px; width: 0px; opacity: 1; }
  100% { height: 15px; width: 28px; opacity: 1; }
}

main section.buttons button:focus { outline: none; }

main section.buttons button span { font-size: 3em; display: block; margin: 0px 0px 0.2em; }

@media screen and (max-width: 600px) {
  main section.buttons { flex-direction: column; margin: 4vh; }
  main section.buttons button { margin: 2vh 2vw; }
}
