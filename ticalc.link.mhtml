<!DOCTYPE html><html lang="en" dir="ltr"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>ticalc.link</title>
    <link rel="stylesheet" href="https://ticalc.link/style.css">
    <link rel="shortcut icon" href="https://ticalc.link/favicon.ico">
    
    
    
  </head>
  <body>
    <main>
      <section id="flow" class="active">
        <h1>ticalc.link</h1>
        <p>Send a file to your calculator over USB from right here in your web browser.</p>
        <section class="buttons">
          <button id="connect" class="active"><span>1</span> Select calculator</button>
          <button id="upload"><span>2</span> Select file</button>
          <button id="start"><span>3</span> Send it!</button>
        </section>
        <p>Currently supported: <span id="supported">TI-84 Plus, TI-84 Plus SE (beta), TI-83 Premium CE (beta), TI-84 Plus CE (beta)</span></p>
      </section>
      <section id="incompatible">
        <h1>ticalc.link</h1>
        <p>Sorry, this web browser does not support WebUSB. Please try using a different web browser!</p>
      </section>
    </main>
    <footer>
      <p>
        This website is still very experimental.
        It comes with absolutely no guarantees.
        So be warned, and please <a href="https://github.com/Timendus/ticalc.link/issues">report any issues</a>.
        It is Open Source, and can be found <a href="https://github.com/Timendus/ticalc.link">on Github</a>.
      </p>
    </footer>
    <section id="popup">
      <section id="content">
        <h2></h2>
        <p></p>
        <section class="buttons"></section>
      </section>
    </section>
  

</body></html>
